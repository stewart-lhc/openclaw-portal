generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Node {
  id           String    @id @default(uuid())
  name         String
  url          String    @unique
  tags         String    @default("")
  notes        String?
  favorite     Boolean   @default(false)
  lastOpenedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
